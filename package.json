{
  "name": "o-telo-backend",
  "version": "1.0.0",
  "description": "Backend GraphQL API for Ô Télo hotel directory app",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --env-file=.env tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "graphql",
    "typescript",
    "postgresql",
    "firebase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@as-integrations/fastify": "^2.1.0",
    "@fastify/cors": "^8.5.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.29.3",
    "fastify": "^4.29.1",
    "firebase-admin": "^12.0.0",
    "graphql": "^16.8.1",
    "graphql-scalars": "^1.22.4",
    "postgres": "^3.4.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "drizzle-kit": "^0.20.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
